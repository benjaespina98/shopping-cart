# Variables de entorno - Copiar como .env y completar

# MongoDB Atlas
# Desarrollo local
MONGODB_URI_DEVELOPMENT=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/shopping_cart_dev?retryWrites=true&w=majority

# Vercel Preview / Testing (OBLIGATORIA en preview para evitar tocar produccion)
MONGODB_URI_PREVIEW=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/shopping_cart_test?retryWrites=true&w=majority

# Vercel Production
MONGODB_URI_PRODUCTION=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/shopping_cart_prod?retryWrites=true&w=majority

# Fallback legacy (opcional)
# MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/shopping_cart_dev?retryWrites=true&w=majority

# JWT
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# App
PORT=5000
NODE_ENV=development
APP_ENV=development
CLIENT_URL=http://localhost:5173
STORE_NAME="Playa y Sol"

# WhatsApp (número del local con código de país, sin + ni espacios)
WHATSAPP_NUMBER=5493534224607

# Admin por defecto (se crea con npm run seed)
ADMIN_EMAIL=admin@mitienda.com
ADMIN_PASSWORD=Admin123!

# Opcional para seed: production | preview | testing | development
# SEED_ENV=development
